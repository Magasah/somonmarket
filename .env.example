# ── Somon Market — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Telegram Bot token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram user ID(s) of admins (comma-separated for multiple)
ADMIN_ID=123456789
ADMIN_IDS=123456789,987654321

# Public HTTPS URL of the WebApp (ngrok for local dev, domain for production)
WEBAPP_URL=https://your-ngrok-or-domain-url.example.com
WEB_APP_URL=https://your-ngrok-or-domain-url.example.com

# Admin panel secret token — pick a strong random string
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=change_me_to_a_strong_random_secret

# Telegram channel for mandatory subscription check
# Username WITHOUT @ (e.g. my_channel)
CHANNEL_USERNAME=your_channel_username
# Numeric channel ID (e.g. -1001234567890)
CHANNEL_ID=-1001234567890
